# RosterIQ Environment Configuration
# Copy this file to .env and fill in your values
# DO NOT commit .env to version control - it contains secrets

# ==================== Database ====================
# PostgreSQL connection string
# Format: postgresql://username:password@host:port/database
DATABASE_URL=postgresql://rosteriq:rosteriq@localhost:5432/rosteriq

# ==================== Authentication ====================
# JWT secret for signing authentication tokens
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
# IMPORTANT: Use a strong random value in production
RIQ_JWT_SECRET=change-me-to-a-random-string

# ==================== Third-Party Integrations ====================
# Tanda POS Integration (Hospitality roster management platform)
TANDA_CLIENT_ID=
TANDA_CLIENT_SECRET=

# Google Places API (Venue location lookups, competitor analysis)
GOOGLE_PLACES_API_KEY=

# OpenWeatherMap API (Weather forecasting for demand prediction)
OPENWEATHERMAP_API_KEY=

# Ticketmaster API (Local events for demand correlation)
TICKETMASTER_API_KEY=

# PredictHQ API (Global events and holiday data)
PREDICTHQ_TOKEN=

# ResDiary API (Restaurant reservation system integration)
RESDIARY_API_KEY=

# NowBookIt API (Restaurant booking integration)
NOWBOOKIT_API_KEY=

# Uber Eats API (Food delivery volume correlation)
UBEREATS_CLIENT_ID=
UBEREATS_CLIENT_SECRET=

# SportRadar API (Sports events for demand prediction)
SPORTRADAR_API_KEY=

# ==================== CORS Configuration ====================
# Comma-separated list of allowed origins for cross-origin requests
# Format: http://localhost:3000,http://localhost:8000,https://app.rosteriq.com
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# ==================== Application Settings ====================
# Set to 'production' in live environments
# This disables debug mode and enables security features
# ENVIRONMENT=development

# ==================== Logging ====================
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
# LOG_LEVEL=INFO
